{
  "name": "michael-pumo",
  "type": "module",
  "private": true,
  "scripts": {
    "sb:login": "storyblok login",
    "sb:logout": "storyblok logout",
    "sb:help": "storyblok --help",
    "sb:components": "storyblok components pull --space 338175 --verbose",
    "sb:types": "storyblok types generate --space 338175 --strict",
    "sb:generate": "npm run sb:components && npm run sb:types",
    "dev": "npm run sb:generate && nuxt dev --host 0.0.0.0",
    "dev:ssl": "local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nuke": "del-cli '.output' 'dist' '.nuxt' 'node_modules' 'package-lock.json'",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/scripts": "^0.13.2",
    "@pinia/nuxt": "^0.11.3",
    "@storyblok/nuxt": "^10.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@unhead/vue": "^2.1.12",
    "@vueuse/core": "^14.2.1",
    "gsap": "^3.14.2",
    "keen-slider": "^6.8.6",
    "lenis": "^1.3.21",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss-nested": "^7.0.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/seo": "^5.1.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "concurrently": "^9.2.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "storyblok": "^4.16.7",
    "storyblok-markdown-richtext": "^1.0.3",
    "typescript": "^6.0.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-svg-loader": "^5.1.1"
  }
}
